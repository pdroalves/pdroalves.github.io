---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';
import yaml from 'js-yaml';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const projectRoot = path.resolve(__dirname, '../..');

interface Publication {
  year: string;
  title: string;
  venue: string;
  abstract?: string;
  note?: string;
  institution?: string;
  type?: string;
  links?: Array<{type: string; url: string}>;
  bibtexInline?: string;
}

interface Talk {
  title: string;
  date: string;
  venue: string;
  location: string;
  type: string;
  link?: string;
}

let publications: {
  preprints: Publication[];
  journal: Publication[];
  conferences: Publication[];
  thesis: Publication[];
} = { preprints: [], journal: [], conferences: [], thesis: [] };

let talks: Talk[] = [];

try {
  const pubPath = path.join(projectRoot, 'src', 'content', 'publications.yaml');
  if (fs.existsSync(pubPath)) {
    const pubData = yaml.load(fs.readFileSync(pubPath, 'utf-8')) as any;
    publications = {
      preprints: pubData?.preprints || [],
      journal: pubData?.journal || [],
      conferences: pubData?.conferences || [],
      thesis: pubData?.thesis || [],
    };
  }
} catch (e) {
  console.error('Error loading publications.yaml:', e);
}

try {
  const talksPath = path.join(projectRoot, 'src', 'content', 'talks.yaml');
  if (fs.existsSync(talksPath)) {
    const talksData = yaml.load(fs.readFileSync(talksPath, 'utf-8')) as any;
    talks = talksData?.talks || [];
  }
} catch (e) {
  console.error('Error loading talks.yaml:', e);
}

function readLocalBibtex(publicationsBaseUrl: string): string | undefined {
  const m = publicationsBaseUrl.match(/\/files\/publications\/([^/]+\.bib)$/);
  if (!m) return undefined;
  const fp = path.join(projectRoot, 'public', 'files', 'publications', m[1]);
  try {
    if (fs.existsSync(fp)) return fs.readFileSync(fp, 'utf-8').trim();
  } catch {
    /* ignore */
  }
  return undefined;
}

function getLinkLabel(link: { type: string; url: string }): string {
  const u = link.url.toLowerCase();
  if (link.type === 'github') return 'GitHub';
  if (link.type === 'scholar') return 'Google Scholar';
  if (u.endsWith('.pdf')) return 'PDF';
  if (link.type === 'eprint') return 'ePrint';
  if (link.type === 'journal') return 'Journal';
  if (link.type === 'paper') return 'Paper';
  if (link.type === 'thesis') return 'Thesis';
  return link.type;
}

const allPublications = [
  ...publications.conferences.map(p => ({ ...p, category: 'Conference' })),
  ...publications.journal.map(p => ({ ...p, category: 'Journal' })),
  ...publications.preprints.map(p => ({ ...p, category: 'Preprint' })),
  ...publications.thesis.map(p => ({ ...p, category: 'Thesis' })),
]
  .sort((a, b) => parseInt(b.year) - parseInt(a.year))
  .map((p) => {
    const bib = p.links?.find((l) => l.type === 'bibtex');
    const bibtexInline = bib?.url ? readLocalBibtex(bib.url) : undefined;
    return { ...p, bibtexInline };
  });

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
}
---

<BaseLayout title="Research" description="Publications, talks, and academic work">
  <div class="page">
    <h1>Research</h1>
    <p class="page-desc">
      My work focuses on privacy-preserving technologies, homomorphic encryption,
      and efficient GPU implementations of cryptographic schemes.
    </p>

    <!-- Tab Navigation -->
    <div class="tabs">
      <button class="tab active" data-tab="publications">Publications</button>
      <button class="tab" data-tab="talks">Talks</button>
    </div>

    <!-- Publications -->
    <section class="tab-content active" id="publications">
      {allPublications.map((pub) => {
        const nonBib = pub.links?.filter((l: any) => l.type !== 'bibtex' && l.url !== '#') ?? [];
        const paperLink =
          nonBib.find((l: any) => l.url.toLowerCase().endsWith('.pdf')) ?? nonBib[0];
        const bibtexLink = pub.links?.find((l: any) => l.type === 'bibtex' && l.url !== '#');
        return (
          <article class="pub">
            <div class="pub-header">
              <span class="pub-year">{pub.year}</span>
              <span class="pub-category">{pub.category}</span>
            </div>
            <h3 class="pub-title">
              {paperLink ? (
                <a href={paperLink.url} target="_blank" rel="noopener noreferrer">{pub.title}</a>
              ) : (
                pub.title
              )}
            </h3>
            <p class="pub-venue">{pub.institution || pub.venue}</p>
            {pub.note && <p class="pub-note">{pub.note}</p>}
            {pub.abstract && (
              <details class="pub-abstract">
                <summary>Abstract</summary>
                <p>{pub.abstract}</p>
              </details>
            )}
            {pub.links && pub.links.length > 0 && (
              <div class="pub-links">
                {pub.links.map((link) => (
                  link.url !== '#' && link.type !== 'bibtex' && (
                    <a href={link.url} target="_blank" rel="noopener noreferrer">
                      {getLinkLabel(link)}
                    </a>
                  )
                ))}
                {bibtexLink && (
                  <span class="pub-bibtex">
                    {pub.bibtexInline ? (
                      <>
                        <textarea class="pub-bib-source" hidden readonly aria-hidden="true">{pub.bibtexInline}</textarea>
                        <button
                          type="button"
                          class="pub-bib-open"
                          data-open-bib
                          data-pub-title={pub.title}
                        >
                          BibTeX
                        </button>
                      </>
                    ) : (
                      <a href={bibtexLink.url} target="_blank" rel="noopener noreferrer">BibTeX</a>
                    )}
                  </span>
                )}
              </div>
            )}
          </article>
        );
      })}
    </section>

    <!-- Talks -->
    <section class="tab-content" id="talks">
      {talks.map((talk) => (
        <article class="talk">
          <div class="talk-meta">
            <span class="talk-date">{formatDate(talk.date)}</span>
            <span class="talk-type">{talk.type}</span>
          </div>
          <h3 class="talk-title">{talk.title}</h3>
          <p class="talk-venue">{talk.venue} &middot; {talk.location}</p>
          {talk.link && talk.link !== '#' && (
            <a href={talk.link} target="_blank" rel="noopener noreferrer" class="talk-link">View slides &rarr;</a>
          )}
        </article>
      ))}
    </section>
  </div>

  <dialog class="bibtex-dialog" id="bibtex-dialog" aria-labelledby="bibtex-dialog-title" tabindex="-1">
    <div class="bibtex-dialog-panel">
      <header class="bibtex-dialog-header">
        <div>
          <h2 id="bibtex-dialog-title" class="bibtex-dialog-title">BibTeX</h2>
          <p id="bibtex-dialog-paper" class="bibtex-dialog-paper" hidden></p>
        </div>
        <div class="bibtex-dialog-header-actions">
          <button
            type="button"
            class="bibtex-dialog-copy"
            id="bibtex-dialog-copy"
            aria-label="Copy BibTeX to clipboard"
          >
            Copy BibTeX
          </button>
          <button type="button" class="bibtex-dialog-close" aria-label="Close">&times;</button>
        </div>
      </header>
      <pre class="bibtex-dialog-pre"><code id="bibtex-dialog-code" class="bibtex-dialog-code"></code></pre>
    </div>
  </dialog>
</BaseLayout>

<style>
  .page h1 {
    margin-bottom: 0.5rem;
  }

  .page-desc {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  /* Tabs */
  .tabs {
    display: flex;
    gap: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }

  .tab {
    background: none;
    border: none;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    position: relative;
    font-family: inherit;
    transition: color 0.15s ease;
  }

  .tab:hover { color: var(--color-text); }

  .tab.active {
    color: var(--color-text);
  }

  .tab.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-text);
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Publications */
  .pub {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .pub:last-child {
    border-bottom: none;
  }

  .pub-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .pub-year {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
  }

  .pub-category {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .pub-title {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
    line-height: 1.4;
  }

  .pub-title a {
    color: var(--color-text);
    text-decoration-color: var(--color-border-light);
  }

  .pub-title a:hover {
    text-decoration-color: var(--color-text);
  }

  .pub-venue {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    margin-bottom: 0.25rem;
  }

  .pub-note {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-style: italic;
    margin-bottom: 0.25rem;
  }

  .pub-abstract {
    margin-top: 0.5rem;
  }

  .pub-abstract summary {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .pub-abstract summary:hover {
    color: var(--color-text);
  }

  .pub-abstract p {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    padding-left: 1rem;
    border-left: 2px solid var(--color-border);
  }

  .pub-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .pub-links a {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .pub-links a:hover {
    color: var(--color-text);
  }

  .pub-bibtex {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pub-bib-open {
    font-size: 0.8rem;
    font-family: inherit;
    padding: 0;
    border: none;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .pub-bib-open:hover {
    color: var(--color-text);
  }

  /* BibTeX dialog (Scholar-style overlay) — fixed center (viewport) */
  .bibtex-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
    max-width: calc(100vw - 2rem);
    width: min(40rem, 100%);
    max-height: min(85vh, 36rem);
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg, #fff);
    color: var(--color-text);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.18);
    overflow: hidden;
  }

  .bibtex-dialog::backdrop {
    background: rgba(0, 0, 0, 0.45);
    cursor: pointer;
  }

  .bibtex-dialog-panel {
    display: flex;
    flex-direction: column;
    max-height: min(70vh, 32rem);
  }

  .bibtex-dialog-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .bibtex-dialog-header-actions {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 0.35rem;
  }

  .bibtex-dialog-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .bibtex-dialog-paper {
    margin: 0.35rem 0 0;
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .bibtex-dialog-close {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    margin: 0;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .bibtex-dialog-close:hover {
    color: var(--color-text);
    background: var(--color-border-light);
  }

  .bibtex-dialog-pre {
    margin: 0;
    padding: 1rem;
    overflow: auto;
    flex: 1;
    min-height: 0;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    font-size: 0.8rem;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
    background: var(--color-bg-secondary, #f6f6f6);
    border-radius: 0;
  }

  .bibtex-dialog-code {
    font-family: inherit;
  }

  .bibtex-dialog-copy {
    font-size: 0.8rem;
    font-family: inherit;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-bg, #fff);
    color: var(--color-text);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }

  .bibtex-dialog-copy:hover {
    border-color: var(--color-text-muted);
    background: var(--color-border-light);
  }

  /* Talks */
  .talk {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .talk:last-child {
    border-bottom: none;
  }

  .talk-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .talk-date {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .talk-type {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .talk-title {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
    line-height: 1.4;
  }

  .talk-venue {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
  }

  .talk-link {
    display: inline-block;
    margin-top: 0.35rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .talk-link:hover {
    color: var(--color-text);
  }
</style>

<script>
  const tabBtns = document.querySelectorAll('.tab');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const targetTab = btn.getAttribute('data-tab');
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      tabContents.forEach(content => {
        content.classList.remove('active');
        if (content.id === targetTab) {
          content.classList.add('active');
        }
      });
    });
  });

  const bibDialog = document.getElementById('bibtex-dialog');
  const bibCode = document.getElementById('bibtex-dialog-code');
  const bibPaper = document.getElementById('bibtex-dialog-paper');
  const bibCopyBtn = document.getElementById('bibtex-dialog-copy');
  const bibCloseBtn = bibDialog?.querySelector('.bibtex-dialog-close');

  document.querySelectorAll('[data-open-bib]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const wrap = btn.closest('.pub-bibtex');
      const ta = wrap?.querySelector('.pub-bib-source');
      if (!ta || !(ta instanceof HTMLTextAreaElement) || !bibCode || !bibDialog) return;
      bibCode.textContent = ta.value;
      const title = btn.getAttribute('data-pub-title');
      if (bibPaper && title) {
        bibPaper.textContent = title;
        bibPaper.hidden = false;
      } else if (bibPaper) {
        bibPaper.textContent = '';
        bibPaper.hidden = true;
      }
      bibDialog.showModal();
      bibDialog.focus();
    });
  });

  bibCloseBtn?.addEventListener('click', () => bibDialog?.close());

  bibDialog?.addEventListener('click', (e) => {
    if (e.target === bibDialog) bibDialog.close();
  });

  bibCopyBtn?.addEventListener('click', async () => {
    const text = bibCode?.textContent ?? '';
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      const prev = bibCopyBtn.textContent;
      bibCopyBtn.textContent = 'Copied';
      setTimeout(() => { bibCopyBtn.textContent = prev; }, 2000);
    } catch {
      const range = document.createRange();
      if (bibCode) {
        range.selectNodeContents(bibCode);
        const sel = window.getSelection();
        sel?.removeAllRanges();
        sel?.addRange(range);
      }
      try {
        document.execCommand('copy');
      } catch { /* ignore */ }
    }
  });
</script>
