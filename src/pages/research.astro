---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';
import yaml from 'js-yaml';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const projectRoot = path.resolve(__dirname, '../..');

interface Publication {
  year: string;
  title: string;
  venue: string;
  abstract?: string;
  note?: string;
  institution?: string;
  type?: string;
  links?: Array<{type: string; url: string}>;
}

interface Talk {
  title: string;
  date: string;
  venue: string;
  location: string;
  type: string;
  link?: string;
}

let publications: {
  preprints: Publication[];
  journal: Publication[];
  conferences: Publication[];
  thesis: Publication[];
} = { preprints: [], journal: [], conferences: [], thesis: [] };

let talks: Talk[] = [];

try {
  const pubPath = path.join(projectRoot, 'src', 'content', 'publications.yaml');
  if (fs.existsSync(pubPath)) {
    const pubData = yaml.load(fs.readFileSync(pubPath, 'utf-8')) as any;
    publications = {
      preprints: pubData?.preprints || [],
      journal: pubData?.journal || [],
      conferences: pubData?.conferences || [],
      thesis: pubData?.thesis || [],
    };
  }
} catch (e) {
  console.error('Error loading publications.yaml:', e);
}

try {
  const talksPath = path.join(projectRoot, 'src', 'content', 'talks.yaml');
  if (fs.existsSync(talksPath)) {
    const talksData = yaml.load(fs.readFileSync(talksPath, 'utf-8')) as any;
    talks = talksData?.talks || [];
  }
} catch (e) {
  console.error('Error loading talks.yaml:', e);
}

const allPublications = [
  ...publications.conferences.map(p => ({ ...p, category: 'Conference' })),
  ...publications.journal.map(p => ({ ...p, category: 'Journal' })),
  ...publications.preprints.map(p => ({ ...p, category: 'Preprint' })),
  ...publications.thesis.map(p => ({ ...p, category: 'Thesis' })),
].sort((a, b) => parseInt(b.year) - parseInt(a.year));

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
}
---

<BaseLayout title="Research" description="Publications, talks, and academic work">
  <div class="page">
    <h1>Research</h1>
    <p class="page-desc">
      My work focuses on privacy-preserving technologies, homomorphic encryption,
      and efficient GPU implementations of cryptographic schemes.
    </p>

    <!-- Tab Navigation -->
    <div class="tabs">
      <button class="tab active" data-tab="publications">Publications</button>
      <button class="tab" data-tab="talks">Talks</button>
    </div>

    <!-- Publications -->
    <section class="tab-content active" id="publications">
      {allPublications.map((pub) => {
        const paperLink = pub.links?.find((l: any) => l.type !== 'bibtex' && l.url !== '#');
        const bibtexLink = pub.links?.find((l: any) => l.type === 'bibtex' && l.url !== '#');
        return (
          <article class="pub">
            <div class="pub-header">
              <span class="pub-year">{pub.year}</span>
              <span class="pub-category">{pub.category}</span>
            </div>
            <h3 class="pub-title">
              {paperLink ? (
                <a href={paperLink.url} target="_blank" rel="noopener noreferrer">{pub.title}</a>
              ) : (
                pub.title
              )}
            </h3>
            <p class="pub-venue">{pub.institution || pub.venue}</p>
            {pub.note && <p class="pub-note">{pub.note}</p>}
            {pub.abstract && (
              <details class="pub-abstract">
                <summary>Abstract</summary>
                <p>{pub.abstract}</p>
              </details>
            )}
            {pub.links && pub.links.length > 0 && (
              <div class="pub-links">
                {pub.links.map((link) => (
                  link.url !== '#' && link.type !== 'bibtex' && (
                    <a href={link.url} target="_blank" rel="noopener noreferrer">
                      {link.type === 'eprint' ? 'ePrint' :
                       link.type === 'journal' ? 'Journal' :
                       link.type === 'conference' ? 'Conference' :
                       link.type === 'paper' ? 'Paper' :
                       link.type === 'scholar' ? 'Scholar' :
                       link.type === 'github' ? 'GitHub' :
                       link.type === 'thesis' ? 'Thesis' : link.type}
                    </a>
                  )
                ))}
                {bibtexLink && (
                  <a href={bibtexLink.url} target="_blank" rel="noopener noreferrer" download>BibTeX</a>
                )}
              </div>
            )}
          </article>
        );
      })}
    </section>

    <!-- Talks -->
    <section class="tab-content" id="talks">
      {talks.map((talk) => (
        <article class="talk">
          <div class="talk-meta">
            <span class="talk-date">{formatDate(talk.date)}</span>
            <span class="talk-type">{talk.type}</span>
          </div>
          <h3 class="talk-title">{talk.title}</h3>
          <p class="talk-venue">{talk.venue} &middot; {talk.location}</p>
          {talk.link && talk.link !== '#' && (
            <a href={talk.link} target="_blank" rel="noopener noreferrer" class="talk-link">View slides &rarr;</a>
          )}
        </article>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .page h1 {
    margin-bottom: 0.5rem;
  }

  .page-desc {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  /* Tabs */
  .tabs {
    display: flex;
    gap: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }

  .tab {
    background: none;
    border: none;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    position: relative;
    font-family: inherit;
    transition: color 0.15s ease;
  }

  .tab:hover { color: var(--color-text); }

  .tab.active {
    color: var(--color-text);
  }

  .tab.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-text);
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Publications */
  .pub {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .pub:last-child {
    border-bottom: none;
  }

  .pub-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .pub-year {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
  }

  .pub-category {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .pub-title {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
    line-height: 1.4;
  }

  .pub-title a {
    color: var(--color-text);
    text-decoration-color: var(--color-border-light);
  }

  .pub-title a:hover {
    text-decoration-color: var(--color-text);
  }

  .pub-venue {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    margin-bottom: 0.25rem;
  }

  .pub-note {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-style: italic;
    margin-bottom: 0.25rem;
  }

  .pub-abstract {
    margin-top: 0.5rem;
  }

  .pub-abstract summary {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .pub-abstract summary:hover {
    color: var(--color-text);
  }

  .pub-abstract p {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    padding-left: 1rem;
    border-left: 2px solid var(--color-border);
  }

  .pub-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .pub-links a {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .pub-links a:hover {
    color: var(--color-text);
  }

  /* Talks */
  .talk {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .talk:last-child {
    border-bottom: none;
  }

  .talk-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .talk-date {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .talk-type {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .talk-title {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
    line-height: 1.4;
  }

  .talk-venue {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
  }

  .talk-link {
    display: inline-block;
    margin-top: 0.35rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .talk-link:hover {
    color: var(--color-text);
  }
</style>

<script>
  const tabBtns = document.querySelectorAll('.tab');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const targetTab = btn.getAttribute('data-tab');
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      tabContents.forEach(content => {
        content.classList.remove('active');
        if (content.id === targetTab) {
          content.classList.add('active');
        }
      });
    });
  });
</script>
