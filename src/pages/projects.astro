---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';
import yaml from 'js-yaml';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const projectRoot = path.resolve(__dirname, '../..');

interface Project {
  title: string;
  description: string;
  link: string;
  tags: string[];
  year: string;
}

let featuredProjects: Project[] = [];
let otherProjects: Project[] = [];

try {
  const portfolioPath = path.join(projectRoot, 'src', 'content', 'portfolio.yaml');
  if (fs.existsSync(portfolioPath)) {
    const portfolioData = yaml.load(fs.readFileSync(portfolioPath, 'utf-8')) as any;
    featuredProjects = portfolioData?.featured || [];
    otherProjects = portfolioData?.others || [];
  }
} catch (e) {
  console.error('Error loading portfolio.yaml:', e);
}

const projectSections: { id: string; heading: string; projects: Project[] }[] = [
  { id: 'featured-heading', heading: 'Featured', projects: featuredProjects },
  { id: 'others-heading', heading: 'Other projects', projects: otherProjects },
];
---

<BaseLayout title="Projects" description="Open source projects and contributions">
  <div class="page">
    <h1>Projects</h1>
    <p class="page-desc">
      Open source projects and contributions focused on cryptography,
      privacy-preserving technologies, and high-performance computing.
    </p>

    {projectSections.map((section) => (
      <section
        class:list={['project-section', { 'project-section--featured': section.id === 'featured-heading' }]}
        aria-labelledby={section.id}
      >
        <h2 id={section.id} class="section-heading">{section.heading}</h2>
        <div class="project-list">
          {section.projects.map((project) => (
            <article class="project">
              <div class="project-header">
                <h3 class="project-title">
                  {project.link && project.link !== '#' ? (
                    <a href={project.link} target="_blank" rel="noopener noreferrer">{project.title}</a>
                  ) : (
                    project.title
                  )}
                </h3>
                <span class="project-year">{project.year}</span>
              </div>
              <p class="project-desc">{project.description}</p>
              {project.tags && project.tags.length > 0 && (
                <div class="project-tags">
                  {project.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .page h1 {
    margin-bottom: 0.5rem;
  }

  .page-desc {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .project-section + .project-section {
    margin-top: 2.5rem;
  }

  .project-section--featured {
    border: 1px solid #000;
    padding: 1rem 1.25rem 1.25rem;
  }

  .section-heading {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .project-list {
    display: flex;
    flex-direction: column;
  }

  .project {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .project:first-child {
    padding-top: 0;
  }

  .project:last-child {
    border-bottom: none;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.35rem;
  }

  .project-title {
    font-size: 1rem;
    font-weight: 500;
  }

  .project-title a {
    color: var(--color-text);
    text-decoration-color: var(--color-border-light);
  }

  .project-title a:hover {
    text-decoration-color: var(--color-text);
  }

  .project-year {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .project-desc {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: #f5f5f5;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }
</style>
