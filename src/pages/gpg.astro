---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';
import yaml from 'js-yaml';
import { fileURLToPath } from 'url';

interface GPGKey {
  keyId?: string;
  fingerprint?: string;
  created?: string;
  expires?: string;
  file?: string;
  email?: string;
}

interface GPGData {
  current?: GPGKey;
  archived?: GPGKey[];
}

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const projectRoot = path.resolve(__dirname, '../..');

let gpgData: GPGData = {};
try {
  const gpgPath = path.join(projectRoot, 'src', 'content', 'gpg.yaml');
  if (fs.existsSync(gpgPath)) {
    gpgData = yaml.load(fs.readFileSync(gpgPath, 'utf-8')) as GPGData;
  }
} catch (e) {
  console.error('Error loading gpg.yaml:', e);
}

function loadKeyFile(filePath: string): string | null {
  try {
    if (filePath.startsWith('/')) {
      filePath = filePath.substring(1);
    }
    const fullPath = path.join(projectRoot, 'public', filePath);
    if (fs.existsSync(fullPath)) {
      return fs.readFileSync(fullPath, 'utf-8');
    }
  } catch (error) {
    console.error(`Error loading key file ${filePath}:`, error);
  }
  return null;
}

const currentKeyContent = gpgData.current?.file ? loadKeyFile(gpgData.current.file) : null;
---

<BaseLayout title="GPG Key" description="GPG public key for encrypted communications">
  <div class="page">
    <h1>GPG Public Key</h1>
    <p class="page-desc">
      My GPG public key for encrypted communications. Import this key to verify my signed messages and send me encrypted emails.
    </p>

    {gpgData.current && (
      <section class="section">
        <h2>Current Key</h2>
        <div class="key-info">
          <div class="info-row">
            <span class="label">Key ID</span>
            <code>{gpgData.current.keyId}</code>
          </div>
          {gpgData.current.fingerprint && (
            <div class="info-row">
              <span class="label">Fingerprint</span>
              <div class="fingerprint-row">
                <code class="fingerprint">{gpgData.current.fingerprint}</code>
                <button class="copy-btn" id="copy-fingerprint" data-value={gpgData.current.fingerprint}>Copy</button>
              </div>
            </div>
          )}
          {gpgData.current.email && (
            <div class="info-row">
              <span class="label">Email</span>
              <span>{gpgData.current.email}</span>
            </div>
          )}
          {gpgData.current.created && (
            <div class="info-row">
              <span class="label">Created</span>
              <span>{new Date(gpgData.current.created).toLocaleDateString()}</span>
            </div>
          )}
          {gpgData.current.expires && (
            <div class="info-row">
              <span class="label">Expires</span>
              <span>{new Date(gpgData.current.expires).toLocaleDateString()}</span>
            </div>
          )}
        </div>

        {currentKeyContent ? (
          <div class="key-content">
            <details>
              <summary>View public key</summary>
              <pre><code>{currentKeyContent}</code></pre>
            </details>
            <a href={gpgData.current.file} download class="download-link">Download key file &darr;</a>
          </div>
        ) : (
          <p class="warning">Key file not found at <code>{gpgData.current.file}</code></p>
        )}
      </section>
    )}

    {gpgData.archived && gpgData.archived.length > 0 && (
      <section class="section">
        <h2>Archived Keys</h2>
        <p class="note">Previous keys kept for historical reference.</p>
        {gpgData.archived.map((key) => {
          const archivedKeyContent = key.file ? loadKeyFile(key.file) : null;
          return (
            <div class="archived-key">
              <h3>Key {key.keyId}</h3>
              <div class="key-info">
                {key.fingerprint && (
                  <div class="info-row">
                    <span class="label">Fingerprint</span>
                    <code>{key.fingerprint}</code>
                  </div>
                )}
                {key.created && (
                  <div class="info-row">
                    <span class="label">Created</span>
                    <span>{new Date(key.created).toLocaleDateString()}</span>
                  </div>
                )}
                {key.expires && (
                  <div class="info-row">
                    <span class="label">Expired</span>
                    <span>{new Date(key.expires).toLocaleDateString()}</span>
                  </div>
                )}
              </div>
              {archivedKeyContent && (
                <details>
                  <summary>View key</summary>
                  <pre><code>{archivedKeyContent}</code></pre>
                  <a href={key.file} download class="download-link">Download &darr;</a>
                </details>
              )}
            </div>
          );
        })}
      </section>
    )}

    <section class="section">
      <h2>How to Import</h2>
      <ol>
        <li>Download the key file above</li>
        <li>Import it: <code>gpg --import [key-file]</code></li>
        <li>Verify the fingerprint matches</li>
        <li>Use this key to verify my signatures or send encrypted emails</li>
      </ol>
    </section>
  </div>
</BaseLayout>

<style>
  .page h1 {
    margin-bottom: 0.5rem;
  }

  .page-desc {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .section {
    margin-bottom: 2rem;
  }

  .section h2 {
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .note {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-style: italic;
    margin-bottom: 1rem;
  }

  .key-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .info-row {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    font-size: 0.9rem;
  }

  .label {
    color: var(--color-text-muted);
    min-width: 6rem;
    flex-shrink: 0;
    font-size: 0.85rem;
  }

  .fingerprint-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .fingerprint {
    word-break: break-all;
    font-size: 0.8rem;
  }

  .copy-btn {
    background: #f5f5f5;
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    cursor: pointer;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: inherit;
    transition: color 0.15s ease;
  }

  .copy-btn:hover {
    color: var(--color-text);
  }

  .key-content {
    margin-top: 1rem;
  }

  details summary {
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    transition: color 0.15s ease;
  }

  details summary:hover {
    color: var(--color-text);
  }

  details pre {
    margin: 0.75rem 0;
    max-height: 250px;
    overflow-y: auto;
    font-size: 0.75rem;
  }

  .download-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .download-link:hover {
    color: var(--color-text);
  }

  .warning {
    color: #b91c1c;
    font-size: 0.85rem;
  }

  .archived-key {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .archived-key:last-child {
    border-bottom: none;
  }

  .archived-key h3 {
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  ol {
    padding-left: 1.5rem;
    line-height: 2;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 500px) {
    .info-row {
      flex-direction: column;
      gap: 0.15rem;
    }

    .label {
      min-width: auto;
    }
  }
</style>

<script>
  const copyBtn = document.getElementById('copy-fingerprint');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const value = copyBtn.getAttribute('data-value');
      if (value) {
        await navigator.clipboard.writeText(value);
        const originalText = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyBtn.textContent = originalText;
        }, 2000);
      }
    });
  }
</script>
