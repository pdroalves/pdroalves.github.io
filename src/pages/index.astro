---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfilePicture from '../components/ProfilePicture.astro';
import { siteConfig } from '../config';
// import { formatBlogDateShort } from '../utils/blogDate';
// import { getCollection } from 'astro:content';
import fs from 'fs';
import path from 'path';
import yaml from 'js-yaml';
import MarkdownIt from 'markdown-it';
import { fileURLToPath } from 'url';

const md = new MarkdownIt();

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const projectRoot = path.resolve(__dirname, '../..');

let aboutHtml = '';
let socialLinks: Array<{name: string; url: string; icon: string; display?: boolean}> = [];
let featuredPublications: Array<{title: string; year: string; venue: string; category?: string; links?: Array<{type: string; url: string}>}> = [];
let featuredProjects: Array<{title: string; description: string; link: string; tags: string[]; year: string}> = [];

// Load about.md
try {
  const aboutPath = path.join(projectRoot, 'src', 'content', 'about.md');
  if (fs.existsSync(aboutPath)) {
    const aboutText = fs.readFileSync(aboutPath, 'utf-8');
    aboutHtml = md.render(aboutText);
  }
} catch (e) {
  console.error('Error loading about.md:', e);
}

// Load social links
try {
  const socialPath = path.join(projectRoot, 'src', 'content', 'social.yaml');
  if (fs.existsSync(socialPath)) {
    const socialData = yaml.load(fs.readFileSync(socialPath, 'utf-8')) as {links?: Array<{name: string; url: string; icon: string; display?: boolean}>};
    socialLinks = (socialData?.links || []).filter(link => link.display !== false);
  }
} catch (e) {
  console.error('Error loading social.yaml:', e);
}

// Load recent publications (5 most recent)
try {
  const pubPath = path.join(projectRoot, 'src', 'content', 'publications.yaml');
  if (fs.existsSync(pubPath)) {
    const pubData = yaml.load(fs.readFileSync(pubPath, 'utf-8')) as any;
    const conferences = pubData?.conferences || [];
    const journal = pubData?.journal || [];
    const preprints = pubData?.preprints || [];
    const thesis = pubData?.thesis || [];
    featuredPublications = [
      ...conferences.map((p: any) => ({ ...p, category: 'Conference' })),
      ...journal.map((p: any) => ({ ...p, category: 'Journal' })),
      ...preprints.map((p: any) => ({ ...p, category: 'Preprint' })),
      ...thesis.map((p: any) => ({ ...p, category: 'Thesis', venue: p.institution })),
    ].sort((a, b) => parseInt(b.year) - parseInt(a.year)).slice(0, 5);
  }
} catch (e) {
  console.error('Error loading publications.yaml:', e);
}

// Featured projects on home (subset of portfolio.yaml; order matches this list)
const homeProjectTitles = ['TFHE-rs', 'Farewell', 'ChainChat', 'OhMyCriterion'] as const;

try {
  const portfolioPath = path.join(projectRoot, 'src', 'content', 'portfolio.yaml');
  if (fs.existsSync(portfolioPath)) {
    const portfolioData = yaml.load(fs.readFileSync(portfolioPath, 'utf-8')) as any;
    const featured = portfolioData?.featured || [];
    const others = portfolioData?.others || [];
    const allProjects: Array<{ title: string; description: string; link: string; tags: string[]; year: string }> = [
      ...featured,
      ...others,
    ];
    featuredProjects = homeProjectTitles
      .map((title) => allProjects.find((p) => p.title === title))
      .filter((p): p is NonNullable<typeof p> => p != null);
  }
} catch (e) {
  console.error('Error loading portfolio.yaml:', e);
}

// Load recent blog posts (3 most recent); hidden on home until there is more to show
// const recentPosts = (await getCollection('articles'))
//   .filter(post => post.data.date)
//   .sort((a, b) => new Date(b.data.date!).getTime() - new Date(a.data.date!).getTime())
//   .slice(0, 3);

const githubLink = socialLinks.find(l => l.icon.toLowerCase() === 'github');
---

<BaseLayout title="Home" description={siteConfig.description}>
  <!-- About card: profile + about (Option B: h1 stays the greeting, not "About Me") -->
  <section class="about-card" aria-label="About">
    <div class="about-card-media">
      <ProfilePicture />
    </div>
    <div class="about-rule" aria-hidden="true"></div>
    <div class="about-card-body">
      <h1>Hi, I'm Pedro</h1>
      <div class="about" set:html={aboutHtml} />
      <div class="links">
        {githubLink && (
          <a href={githubLink.url} target="_blank" rel="noopener noreferrer">GitHub</a>
        )}
        {socialLinks.filter(l => l.icon.toLowerCase() !== 'github').slice(0, 4).map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer">{link.name}</a>
        ))}
      </div>
    </div>
  </section>

  {/* Recent Posts: hidden on home until there is more to show; uncomment frontmatter + imports too
  {recentPosts.length > 0 && (
    <section class="section">
      <h2>Recent posts</h2>
      <div class="post-table-wrap">
        <table class="post-table">
          <thead>
            <tr>
              <th scope="col">Title</th>
              <th scope="col">Date</th>
            </tr>
          </thead>
          <tbody>
            {recentPosts.map((post) => (
              <tr>
                <td>
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </td>
                <td class="post-table-date">{formatBlogDateShort(post.data.date!)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <a href="/blog" class="see-all">See all posts &rarr;</a>
    </section>
  )}
  */}

  <!-- Recent Publications -->
  {featuredPublications.length > 0 && (
    <section class="section">
      <h2>Recent publications</h2>
      <div class="pub-list">
        {featuredPublications.map((pub) => {
          const paperLink = pub.links?.find((l: any) => l.type !== 'bibtex' && l.url !== '#');
          return (
            <div class="pub-item">
              <span class="pub-date">{pub.year}</span>
              <div class="pub-info">
                {paperLink ? (
                  <a href={paperLink.url} target="_blank" rel="noopener noreferrer" class="pub-title">{pub.title}</a>
                ) : (
                  <span class="pub-title">{pub.title}</span>
                )}
                <span class="pub-venue">{pub.venue}</span>
              </div>
            </div>
          );
        })}
      </div>
      <a href="/research" class="see-all">See all publications &rarr;</a>
    </section>
  )}

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="section">
      <h2>Projects</h2>
      <div class="project-list">
        {featuredProjects.map((project) => (
          <div class="project-item">
            <div class="project-info">
              {project.link && project.link !== '#' ? (
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="project-name">{project.title}</a>
              ) : (
                <span class="project-name">{project.title}</span>
              )}
              <span class="project-desc">{project.description}</span>
            </div>
          </div>
        ))}
      </div>
      <a href="/projects" class="see-all">See all projects &rarr;</a>
    </section>
  )}
</BaseLayout>

<style>
  .about-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin-bottom: 3rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: var(--color-bg);
  }

  .about-card-media {
    flex-shrink: 0;
    padding-top: 0.25rem;
  }

  .about-rule {
    flex-shrink: 0;
    width: 1px;
    height: 7rem;
    margin-top: 0.25rem;
    background: var(--color-border);
    align-self: flex-start;
  }

  .about-card-body {
    flex: 1;
    min-width: 0;
  }

  .about-card-body h1 {
    margin-bottom: 0.75rem;
  }

  .about {
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .about :global(h1) {
    display: none;
  }

  .about :global(p) {
    margin-bottom: 0.75rem;
    color: var(--color-text-secondary);
  }

  .about :global(p:last-child) {
    margin-bottom: 0;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .links a {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .links a:hover {
    color: var(--color-text);
  }

  /* Sections */
  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-rule);
  }

  .see-all {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .see-all:hover {
    color: var(--color-text);
  }

  /* Recent posts table */
  .post-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .post-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .post-table th,
  .post-table td {
    padding: 0.5rem 0.65rem;
    text-align: left;
    vertical-align: top;
    border: 1px solid var(--color-rule);
  }

  .post-table thead th {
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    background: #fafafa;
  }

  .post-table tbody td:first-child {
    font-weight: 500;
    width: 100%;
  }

  .post-table tbody a {
    color: var(--color-text);
    text-decoration-color: var(--color-border-light);
  }

  .post-table tbody a:hover {
    text-decoration-color: var(--color-text);
  }

  .post-table-date {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* Publications */
  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pub-item {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  .pub-date {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    min-width: 2.5rem;
  }

  .pub-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .pub-title {
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  a.pub-title {
    text-decoration-color: var(--color-border-light);
  }

  a.pub-title:hover {
    text-decoration-color: var(--color-text);
  }

  .pub-venue {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  /* Projects */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .project-name {
    font-weight: 500;
    font-size: 0.95rem;
  }

  a.project-name {
    text-decoration-color: var(--color-border-light);
  }

  a.project-name:hover {
    text-decoration-color: var(--color-text);
  }

  .project-desc {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 500px) {
    .about-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .about-rule {
      display: none;
    }

    .links {
      justify-content: center;
    }

    .pub-item {
      flex-direction: column;
      gap: 0.1rem;
    }
  }
</style>
