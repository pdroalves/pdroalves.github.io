---
import { siteConfig } from '../config';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/files/cv_pdroalves.pdf', label: 'CV', newTab: true },
  { href: '/research', label: 'Research' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
] as const;

const currentPath = Astro.url.pathname;
const navBrand = siteConfig.author;
---

<header class="topbar">
  <div class="topbar-inner">
    <a href="/" class="brand">{navBrand}</a>
    <nav class="nav-links" aria-label="Primary">
      {navLinks.map((link) => {
        const isPageActive =
          !('newTab' in link && link.newTab) &&
          (currentPath === link.href ||
            (link.href !== '/' && currentPath.startsWith(link.href)));
        return (
          <a
            href={link.href}
            class:list={['nav-link', { active: isPageActive }]}
            {...('newTab' in link && link.newTab ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  @supports not (backdrop-filter: blur(1px)) {
    .topbar {
      background: var(--color-bg);
    }
  }

  .topbar-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.65rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
  }

  .brand {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .brand:hover {
    opacity: 0.75;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0 1rem;
    row-gap: 0.35rem;
  }

  .nav-link {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-text-muted);
  }

  .nav-link.active {
    color: var(--color-text);
    font-weight: 600;
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .topbar-inner {
      padding: 0.55rem 1rem;
    }
  }
</style>
