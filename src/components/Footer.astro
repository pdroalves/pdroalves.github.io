---
import { siteConfig } from '../config';
---

<footer class="footer">
  <p>&copy; {new Date().getFullYear()} {siteConfig.author}</p>
</footer>

<style>
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-rule);
    text-align: center;
  }

  .footer p {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin: 0;
  }
</style>
